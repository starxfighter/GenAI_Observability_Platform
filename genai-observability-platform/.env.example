# ==============================================
# GenAI Observability Platform - Environment Configuration
# ==============================================
# Copy this file to .env and fill in your values.
# All variables are prefixed with OBSERVABILITY_

# ==============================================
# Application Settings
# ==============================================
OBSERVABILITY_APP_NAME=GenAI Observability API
OBSERVABILITY_ENVIRONMENT=dev  # dev, staging, prod
OBSERVABILITY_DEBUG=false
OBSERVABILITY_LOG_LEVEL=INFO
OBSERVABILITY_API_BASE_URL=http://localhost:8000
OBSERVABILITY_FRONTEND_URL=http://localhost:5173

# ==============================================
# AWS Configuration
# ==============================================
OBSERVABILITY_AWS_REGION=us-east-1
# AWS credentials are typically provided via:
# - Environment variables: AWS_ACCESS_KEY_ID, AWS_SECRET_ACCESS_KEY
# - IAM role (recommended for production)
# - AWS credentials file

# ==============================================
# DynamoDB Tables
# ==============================================
OBSERVABILITY_TRACES_TABLE=genai-observability-traces
OBSERVABILITY_AGENTS_TABLE=genai-observability-agents
OBSERVABILITY_ALERTS_TABLE=genai-observability-alerts
OBSERVABILITY_API_KEYS_TABLE=genai-observability-api-keys
OBSERVABILITY_INVESTIGATIONS_TABLE=genai-observability-investigations
OBSERVABILITY_REMEDIATIONS_TABLE=genai-observability-remediations
OBSERVABILITY_INTEGRATIONS_TABLE=genai-observability-integrations

# ==============================================
# Timestream (Metrics Storage)
# ==============================================
OBSERVABILITY_TIMESTREAM_DATABASE=genai-observability
OBSERVABILITY_TIMESTREAM_TABLE=metrics

# ==============================================
# OpenSearch (Log Search)
# ==============================================
OBSERVABILITY_OPENSEARCH_ENDPOINT=https://your-opensearch-domain.region.es.amazonaws.com
OBSERVABILITY_OPENSEARCH_INDEX_PREFIX=observability

# ==============================================
# S3 (Raw Events Storage)
# ==============================================
OBSERVABILITY_RAW_EVENTS_BUCKET=genai-observability-raw-events

# ==============================================
# JWT Authentication
# ==============================================
OBSERVABILITY_JWT_SECRET_KEY=your-super-secret-key-change-in-production
OBSERVABILITY_JWT_ALGORITHM=HS256
OBSERVABILITY_JWT_EXPIRATION_HOURS=24

# ==============================================
# SSO - Google OIDC
# ==============================================
# Get credentials from: https://console.cloud.google.com/apis/credentials
OBSERVABILITY_GOOGLE_CLIENT_ID=
OBSERVABILITY_GOOGLE_CLIENT_SECRET=

# ==============================================
# SSO - Okta OIDC
# ==============================================
# Get credentials from your Okta Admin Console
OBSERVABILITY_OKTA_DOMAIN=your-domain.okta.com
OBSERVABILITY_OKTA_CLIENT_ID=
OBSERVABILITY_OKTA_CLIENT_SECRET=

# ==============================================
# SSO - Azure AD OIDC
# ==============================================
# Get credentials from Azure Portal > App Registrations
OBSERVABILITY_AZURE_TENANT_ID=
OBSERVABILITY_AZURE_CLIENT_ID=
OBSERVABILITY_AZURE_CLIENT_SECRET=

# ==============================================
# SSO - Auth0 OIDC
# ==============================================
# Get credentials from your Auth0 Dashboard
OBSERVABILITY_AUTH0_DOMAIN=your-domain.auth0.com
OBSERVABILITY_AUTH0_CLIENT_ID=
OBSERVABILITY_AUTH0_CLIENT_SECRET=

# ==============================================
# SSO - SAML 2.0
# ==============================================
# Configure with your Identity Provider's metadata
OBSERVABILITY_SAML_IDP_ENTITY_ID=
OBSERVABILITY_SAML_SSO_URL=
OBSERVABILITY_SAML_SLO_URL=
OBSERVABILITY_SAML_CERTIFICATE=  # Base64 encoded certificate
OBSERVABILITY_SAML_SP_ENTITY_ID=https://observability.example.com/auth/saml/metadata

# ==============================================
# CORS Configuration
# ==============================================
# Comma-separated list of allowed origins
OBSERVABILITY_CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ==============================================
# Rate Limiting
# ==============================================
OBSERVABILITY_RATE_LIMIT_REQUESTS=100
OBSERVABILITY_RATE_LIMIT_WINDOW_SECONDS=60

# ==============================================
# Third-Party Integrations
# ==============================================
OBSERVABILITY_JIRA_DEFAULT_PROJECT=
OBSERVABILITY_SLACK_DEFAULT_CHANNEL=
OBSERVABILITY_PAGERDUTY_ROUTING_KEY=

# ==============================================
# Natural Language Query
# ==============================================
OBSERVABILITY_NLQ_MODEL=claude-3-sonnet
OBSERVABILITY_NLQ_MAX_TOKENS=4096

# ==============================================
# PII Redaction
# ==============================================
OBSERVABILITY_PII_REDACTION_ENABLED=true
OBSERVABILITY_PII_REDACTION_STRATEGY=mask  # mask, hash, remove

# ==============================================
# Multi-Region Configuration
# ==============================================
OBSERVABILITY_PRIMARY_REGION=us-east-1
OBSERVABILITY_SECONDARY_REGION=us-west-2
OBSERVABILITY_ENABLE_MULTI_REGION=false
OBSERVABILITY_ROUTING_STRATEGY=failover  # failover, round_robin, latency_based

# ==============================================
# Frontend Configuration (for Vite)
# ==============================================
VITE_API_URL=http://localhost:8000/api
